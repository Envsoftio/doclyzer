# Copy to .env and adjust. Used by API and docker compose.

# Database (API connects here; compose uses POSTGRES_* for the container)
DATABASE_URL=postgresql://doclyzer:doclyzer_dev_password@localhost:5432/doclyzer

# Better Auth
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_BASE_PATH=/v1/auth
BETTER_AUTH_SESSION_EXPIRES_IN_SECONDS=2592000
BETTER_AUTH_SESSION_UPDATE_AGE_SECONDS=86400
BETTER_AUTH_RESET_REDIRECT_URL=http://localhost:3001/reset-password
SUPERADMIN_EMAILS=admin@doclyzer.local
SUPERADMIN_MFA_TEST_CODE=654321
SUPERADMIN_MFA_CHALLENGE_TTL_SECONDS=300
SUPERADMIN_MFA_TRUST_TTL_SECONDS=600
SUPERADMIN_MFA_MAX_ATTEMPTS=5
SUPERADMIN_MFA_LOCKOUT_SECONDS=900

# Docker Postgres (optional; defaults shown)
POSTGRES_DB=doclyzer
POSTGRES_USER=doclyzer
POSTGRES_PASSWORD=doclyzer_dev_password
POSTGRES_PORT=5432
REDIS_PORT=6379

# Backblaze B2 (optional; set B2_DISABLED=true for local dev without B2)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002
B2_DISABLED=true

# Share links (base URL used to construct share link URLs)
SHARE_BASE_URL=http://localhost:3001

# Razorpay (payment gateway for credit pack purchases)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=change-me-in-production
RAZORPAY_WEBHOOK_SECRET=change-me-in-production
RAZORPAY_PLAN_ID_PRO=plan_placeholder

# AI Report Summarisation (optional; set REPORT_SUMMARY_ENABLED=false to disable)
REPORT_SUMMARY_ENABLED=false
REPORT_SUMMARY_PROVIDER=http
REPORT_SUMMARY_HTTP_URL=http://localhost:8080
REPORT_SUMMARY_TIMEOUT_MS=10000

# OpenDataLoader parser (optional)
OPENDATALOADER_ENABLED=true
OPENDATALOADER_CLI_COMMAND=opendataloader-pdf
OPENDATALOADER_TIMEOUT_MS=180000
OPENDATALOADER_EXTRA_ARGS=

# Docling OCR service (used for image-origin uploads)
DOCLING_OCR_ENABLED=true
DOCLING_OCR_BASE_URL=http://127.0.0.1:5002
DOCLING_OCR_TIMEOUT_MS=180000
DOCLING_OCR_ENGINE=rapidocr

# AI Lab Extraction Fallback (optional; uses sanitized lab rows only, no patient identity fields)
REPORT_LAB_AI_FALLBACK_ENABLED=false
REPORT_LAB_AI_FALLBACK_OPENAI_API_KEY=
REPORT_LAB_AI_FALLBACK_OPENAI_MODEL=gpt-5-mini
REPORT_LAB_AI_FALLBACK_OPENAI_BASE_URL=https://api.openai.com/v1
REPORT_LAB_AI_FALLBACK_TIMEOUT_MS=12000
REPORT_LAB_AI_FALLBACK_MIN_CONFIDENCE=0.72
